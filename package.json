{
  "name": "@dukepan2005/openclaw-claude-code-cli-plugin",
  "version": "2.1.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js --minify --external:openclaw --external:openclaw/plugin-sdk",
    "prepare": "npm run build",
    "test": "tsx tests/session-filter.test.ts"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "claude",
    "claude-code",
    "coding-agent",
    "ai",
    "anthropic",
    "agent",
    "code-generation",
    "automation",
    "cli",
    "background-process",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dukepan2005/openclaw-claude-code-cli-plugin.git"
  },
  "homepage": "https://github.com/dukepan2005/openclaw-claude-code-cli-plugin#readme",
  "bugs": {
    "url": "https://github.com/dukepan2005/openclaw-claude-code-cli-plugin/issues"
  },
  "license": "MIT",
  "author": "dukepan2005",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenClaw Claude Code CLI Plugin - orchestrates Claude Code CLI sessions as managed background processes using spawn. Supports any Claude-compatible model service. Forked from alizarion/openclaw-claude-code-plugin."
}
